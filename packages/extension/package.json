{
  "name": "vba-extension",
  "displayName": "VBA Extension",
  "version": "0.1.0",
  "private": true,
  "main": "dist/extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onLanguage:vba"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vba.extract",
        "title": "VBA: Extract"
      },
      {
        "command": "vba.combine",
        "title": "VBA: Combine"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "echo \"No tests yet (extension)\"",
    "lint": "echo \"No lint config yet (extension)\"",
    "clean": "if exist dist rmdir /s /q dist"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0"
  },
  "dependencies": {
    "@vba/server": "0.1.0"
  }
}
